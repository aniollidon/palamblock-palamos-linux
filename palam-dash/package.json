{
  "name": "palam-dash",
  "version": "3.0.8",
  "description": "Aplicació Electron per a PalamOS Dashboard",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build-linux": "electron-builder --linux",
    "publish": "electron-builder --linux --publish always",
    "install:deps": "./install-dependencies-ubuntu.sh",
    "install:service": "sudo ./install-service-linux.sh",
    "install:startup": "./install-startup-linux.sh"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.6.2",
    "ip": "^2.0.1",
    "sharp": "^0.33.5",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.palamos.dash",
    "productName": "PalamOS-Dashboard",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "aniollidon",
      "repo": "palamblock-palamos-linux",
      "releaseType": "release"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png",
      "category": "System",
      "description": "Dashboard per PalamOS - Sistema de gestió d'aula"
    }
  },
  "author": {
    "name": "PalamBlock Team",
    "email": "info@palamblock.cat"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aniollidon/palamblock-palamos-linux.git"
  }
}
